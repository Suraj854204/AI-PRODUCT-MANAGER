generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AgentType {
  RESEARCH
  PRD
  STORIES
  ROADMAP
  MARKET_ANALYSIS
  PERSONA
  RISK
}

enum StoryPriority {
  HIGH
  MEDIUM
  LOW
}

enum StoryStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String?
  plan         Plan      @default(FREE)
  projectCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  title       String
  idea        String        @db.Text
  industry    String?
  targetUsers String?
  status      ProjectStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  outputs     AgentOutput[]
  userStories UserStory[]
  roadmap     Roadmap?
  competitors Competitor[]
  personas    Persona[]
  risks       Risk[]

  @@map("projects")
}

model AgentOutput {
  id        String    @id @default(cuid())
  projectId String
  type      AgentType
  content   Json
  tokens    Int       @default(0)
  duration  Int       @default(0)
  createdAt DateTime  @default(now())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@map("agent_outputs")
}

model UserStory {
  id          String        @id @default(cuid())
  projectId   String
  epicName    String
  title       String
  asA         String
  iWant       String
  soThat      String
  priority    StoryPriority @default(MEDIUM)
  storyPoints Int           @default(3)
  status      StoryStatus   @default(TODO)
  jiraKey     String?
  createdAt   DateTime      @default(now())
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("user_stories")
}

model Roadmap {
  id        String   @id @default(cuid())
  projectId String   @unique
  phases    Json
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("roadmaps")
}

model Competitor {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  website    String?
  strengths  String[]
  weaknesses String[]
  pricing    String?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("competitors")
}

model Persona {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  age        String
  role       String
  painPoints String[]
  goals      String[]
  techSavvy  String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("personas")
}

model Risk {
  id          String   @id @default(cuid())
  projectId   String
  category    String
  title       String
  description String
  severity    String
  mitigation  String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("risks")
}
